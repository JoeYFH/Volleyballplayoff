{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".git",
      "**/.gitignore",
      "**/README.md",
      "functions/**"
    ],
    "rewrites": [
      { "source": "/share/**", "function": "og" },
      { "source": "/og-image/**", "function": "ogImage" }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs18"
  }
}
