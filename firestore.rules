rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 場次：所有人可讀，登入者可建立，只有建立者可修改/刪除
    match /sessions/{sessionId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.createdBy ||
         request.auth.token.email in ['abc8038570@gmail.com', 'joehuangyf@gmail.com']);

      // 報名：所有人可讀，登入者可建立自己的，本人/場主/管理員可修改或刪除
      match /signups/{signupId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null &&
          (request.auth.uid == resource.data.uid ||
           request.auth.uid == get(/databases/$(database)/documents/sessions/$(sessionId)).data.createdBy ||
           request.auth.token.email in ['abc8038570@gmail.com', 'joehuangyf@gmail.com']);
        allow update: if request.auth != null &&
          (request.auth.uid == resource.data.uid ||
           request.auth.uid == get(/databases/$(database)/documents/sessions/$(sessionId)).data.createdBy ||
           request.auth.token.email in ['abc8038570@gmail.com', 'joehuangyf@gmail.com']);
      }
    }

    // 範本：只有本人可以讀寫，完全私有
    match /users/{userId}/templates/{templateId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 我的報名記錄：只有本人或管理員可以讀寫
    match /users/{userId}/mySignups/{signupId} {
      allow read, write: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.email in ['abc8038570@gmail.com', 'joehuangyf@gmail.com']
      );
    }

    // 取消的報名記錄：只有本人或管理員可以讀寫
    match /users/{userId}/cancelledSignups/{signupId} {
      allow read, write: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.email in ['abc8038570@gmail.com', 'joehuangyf@gmail.com']
      );
    }

    // 管理員 collectionGroup 查詢用（跨用戶掃描孤兒資料）
    match /{path=**}/mySignups/{signupId} {
      allow read, write: if request.auth != null &&
        request.auth.token.email in ['abc8038570@gmail.com', 'joehuangyf@gmail.com'];
    }

    match /{path=**}/cancelledSignups/{signupId} {
      allow read, write: if request.auth != null &&
        request.auth.token.email in ['abc8038570@gmail.com', 'joehuangyf@gmail.com'];
    }

    // 設定：所有人可讀
    match /config/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 意見回饋：登入者可建立，只有管理員可讀
    match /feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null &&
        request.auth.token.email in ['abc8038570@gmail.com', 'joehuangyf@gmail.com'];
      allow delete: if request.auth != null &&
        request.auth.token.email in ['abc8038570@gmail.com', 'joehuangyf@gmail.com'];
    }
  }
}
